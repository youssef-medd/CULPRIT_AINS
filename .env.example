# Copy to .env and fill in. .env is gitignored.

# --- LLM provider (NVIDIA NIM, OpenAI-compatible API) ---
NVIDIA_API_KEY=nvapi-...

# Model ids (NVIDIA integrate endpoint). Override per-role if you want.
CULPRIT_JUDGE_MODEL=deepseek-ai/deepseek-v4-pro
CULPRIT_AGENT_MODEL=deepseek-ai/deepseek-v4-pro
CULPRIT_TAGGER_MODEL=deepseek-ai/deepseek-v4-pro

# --- Evaluation knobs ---
# Confidence threshold tau: a component verdict counts as a decisive
# suspect only when its confidence >= this value.
CULPRIT_TAU=0.7
# Self-consistency samples per judge (agreement -> confidence).
CULPRIT_JUDGE_SAMPLES=5

# --- Storage / paths (relative to repo root unless absolute) ---
CULPRIT_DB_PATH=data/culprit.db
CULPRIT_OUTPUT_DIR=data/outputs
